# Server
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
API_BASE_URL=http://localhost:4000

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=pokemon_store

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CODE_ENCRYPTION_KEY=replace_with_a_long_random_secret_for_code_cards
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin123!

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
CLIENT_SUCCESS_URL=http://localhost:5173/order-confirmation?session_id={CHECKOUT_SESSION_ID}
CLIENT_CANCEL_URL=http://localhost:5173/checkout
STORE_CURRENCY=gbp

# Shippo - UK-only store
SHIPPO_API_TOKEN=shippo_test_replace_me
SHIP_FROM_NAME=Cannon Cards TCG
SHIP_FROM_COMPANY=Cannon Cards TCG
SHIP_FROM_STREET1=1 Example Street
SHIP_FROM_CITY=Retford
SHIP_FROM_STATE=Nottinghamshire
SHIP_FROM_ZIP=DN22 0AA
SHIP_FROM_COUNTRY=GB
SHIP_FROM_PHONE=+441234567890
SHIP_FROM_EMAIL=shipping@example.com

# Default parcel values used for single cards or incomplete sealed data
DEFAULT_SINGLE_WEIGHT_GRAMS=30
DEFAULT_SINGLE_LENGTH_CM=20
DEFAULT_SINGLE_WIDTH_CM=15
DEFAULT_SINGLE_HEIGHT_CM=1
DEFAULT_SEALED_WEIGHT_GRAMS=500
DEFAULT_SEALED_LENGTH_CM=25
DEFAULT_SEALED_WIDTH_CM=18
DEFAULT_SEALED_HEIGHT_CM=8

# PokeWallet
POKEWALLET_API_KEY=replace_me
POKEWALLET_API_BASE_URL=https://api.pokewallet.io

# Frontend
VITE_API_URL=http://localhost:4000/api
